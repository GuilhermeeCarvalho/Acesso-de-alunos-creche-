# ==================== Variáveis de Configuração ====================
# Copie este arquivo para .env e ajuste os valores conforme necessário

# ==================== BANCO DE DADOS ====================
POSTGRES_DB=creche
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_2024
POSTGRES_PORT=5432
POSTGRES_DATA_PATH=./backend/postgres_data

# ==================== BACKEND (Spring Boot) ====================
BACKEND_PORT=8080
SPRING_JPA_SHOW_SQL=false
HIBERNATE_DDL_AUTO=update

# ==================== FRONTEND ====================
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080

# ==================== DESENVOLVIMENTO ====================
# Configure para desenvolvimento/produção
ENVIRONMENT=development
